{
  "routes": [
    { "route": "/",                        "rewrite": "/index.html" },
    { "route": "/home",                    "rewrite": "/home.html" },
    { "route": "/enrollment",              "rewrite": "/enrollment/index.html" },
    { "route": "/enrollment/sign*",        "rewrite": "/enrollment/sign.html" },
    { "route": "/enrollment/inperson",     "rewrite": "/enrollment/inperson.html" },
    { "route": "/enrollment/countersign*", "rewrite": "/enrollment/countersign.html" },
    { "route": "/files",                   "rewrite": "/files/index.html" },
    { "route": "/upload",                  "rewrite": "/upload/index.html" },
    { "route": "/dashboard",               "rewrite": "/dashboard/index.html" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{css,scss,js,png,gif,ico,jpg,svg,json,woff,woff2,ttf}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": { "apiRuntime": "node:22" }
}
