{
  "routes": [
    {
      "route": "/v",
      "rewrite": "/samples/index.html",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/v/*",
      "rewrite": "/samples/index.html",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/samples",
      "rewrite": "/samples/index.html",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/samples/*",
      "rewrite": "/samples/index.html",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/api/getFlipbook",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/layout",
      "rewrite": "/layout/index.html"
    },
    {
      "route": "/setup",
      "rewrite": "/setup/index.html"
    },
    {
      "route": "/",
      "rewrite": "/index.html"
    },
    {
      "route": "/home",
      "rewrite": "/home.html"
    },
    {
      "route": "/enrollment/dashboard",
      "rewrite": "/enrollment/dashboard.html"
    },
    {
      "route": "/enrollment",
      "rewrite": "/enrollment/index.html"
    },
    {
      "route": "/sign*",
      "rewrite": "/sign.html"
    },
    {
      "route": "/enrollment/inperson",
      "rewrite": "/enrollment/inperson.html"
    },
    {
      "route": "/countersign*",
      "rewrite": "/countersign.html"
    },
    {
      "route": "/files",
      "rewrite": "/files/index.html"
    },
    {
      "route": "/upload",
      "rewrite": "/upload/index.html"
    },
    {
      "route": "/approvals",
      "rewrite": "/approvals/index.html"
    },
    {
      "route": "/approvals/dashboard",
      "rewrite": "/approvals/dashboard.html"
    },
    {
      "route": "/clients",
      "rewrite": "/clients/index.html"
    },
    {
      "route": "/prospects",
      "rewrite": "/prospects/index.html"
    },
    {
      "route": "/respond",
      "rewrite": "/respond/index.html"
    },
    {
      "route": "/bookings",
      "rewrite": "/bookings/index.html"
    },
    {
      "route": "/emails",
      "rewrite": "/emails/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "*.{css,scss,js,png,gif,ico,jpg,svg,json,woff,woff2,ttf}",
      "/samples/*",
      "/v/*"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
